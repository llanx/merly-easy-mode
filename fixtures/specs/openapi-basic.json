{
  "openapi": "3.1.0",
  "info": {
    "title": "Orders API",
    "version": "1.0.0"
  },
  "paths": {
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
        "responses": {
          "200": {
            "description": "Order list returned"
          }
        }
      },
      "post": {
        "operationId": "createOrder",
        "summary": "Create order",
        "responses": {
          "201": {
            "description": "Order created"
          },
          "409": {
            "description": "Duplicate idempotency key"
          }
        }
      }
    }
  }
}
