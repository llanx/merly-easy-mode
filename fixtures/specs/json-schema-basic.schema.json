{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order",
  "type": "object",
  "required": ["id", "status", "totalCents"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["created", "paid", "canceled"]
    },
    "totalCents": {
      "type": "integer"
    }
  }
}
