MERLY_BASE_URL=http://127.0.0.1:4201

# Optional: Merly license key. This is not used as an API credential.
MERLY_LICENSE_KEY=

# Prefer an API key for local MCP use.
# MERLY_API_KEY=dif_pk_...
MERLY_API_KEY=

# DIF-only key from http://127.0.0.1:4202/dif-api-keys.
# Use this for merly_verify_snippet when a full Mentor API key is not available yet.
MERLY_DIF_API_KEY=

# Fallback if using a JWT access token from /api/v2/auth/login.
# MERLY_BEARER_TOKEN=eyJ...
MERLY_BEARER_TOKEN=

# Optional for one-time login through the debug CLI.
MERLY_EMAIL=
MERLY_PASSWORD=
